# ─────────────────────────────────────────────────────────
#  School Management System — Environment Variables
#  Copy this file to .env and fill in your own values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

SCHOOL_DB_HOST=localhost
SCHOOL_DB_PORT=3306
SCHOOL_DB_USER=school_user
SCHOOL_DB_PASS=school_pass
SCHOOL_DB_NAME=school_db

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
