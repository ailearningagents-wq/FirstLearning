# ─────────────────────────────────────────────────────────────────
# Prompt Engineering with Python — Environment Variables Template
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual API keys.
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# Make sure .env is in your .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────
# Required for most modules. Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Default model to use. gpt-4o-mini is highly cost-efficient for learning.
# Options: gpt-4o-mini | gpt-4o | gpt-4-turbo | gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Base URL override (leave blank for default OpenAI endpoint)
# Use this to point at a local OpenAI-compatible server (e.g., Ollama, LM Studio)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── Anthropic (Claude) ────────────────────────────────────────────
# Optional. Used when swapping providers in utils/llm_client.py
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Provider Selection ────────────────────────────────────────────
# Which LLM provider to use by default: openai | anthropic | local
LLM_PROVIDER=openai

# ── Cost & Safety Controls ───────────────────────────────────────
# Maximum dollars to spend in a single script run (safety guard)
MAX_COST_USD=1.00

# If set to "true", prints prompts but does NOT call the API (free preview)
DRY_RUN=false

# ── Logging ──────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to write structured logs (leave blank to log to stdout only)
LOG_FILE=logs/prompt_engineering.log
